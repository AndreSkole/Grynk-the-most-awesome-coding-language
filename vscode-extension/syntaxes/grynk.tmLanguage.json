{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "grynk",
    "patterns": [
        {
            "include": "#comments"
        },
        {
            "include": "#strings"
        },
        {
            "include": "#keywords"
        },
        {
            "include": "#constants"
        },
        {
            "include": "#functions"
        },
        {
            "include": "#builtins"
        },
        {
            "include": "#operators"
        },
        {
            "include": "#numbers"
        }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.number-sign.grynk",
                    "match": "#.*$"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.grynk",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "constant.character.escape.grynk",
                            "match": "\\\\."
                        },
                        {
                            "name": "variable.other.interpolated.grynk",
                            "match": "\\{.*?\\}"
                        }
                    ]
                },
                {
                    "name": "string.quoted.single.grynk",
                    "begin": "'",
                    "end": "'",
                    "patterns": [
                        {
                            "name": "constant.character.escape.grynk",
                            "match": "\\\\."
                        }
                    ]
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.grynk",
                    "match": "\\b(if|elif|else|loop|times|for|in|while|break|continue|return|try|catch|throw|match|case)\\b"
                },
                {
                    "name": "storage.type.grynk",
                    "match": "\\b(let|mut|fn)\\b"
                },
                {
                    "name": "keyword.operator.logical.grynk",
                    "match": "\\b(and|or|not)\\b"
                }
            ]
        },
        "constants": {
            "patterns": [
                {
                    "name": "constant.language.grynk",
                    "match": "\\b(true|false|null)\\b"
                }
            ]
        },
        "functions": {
            "patterns": [
                {
                    "name": "meta.function.grynk",
                    "match": "\\bfn\\s+([a-zA-Z_]\\w*)\\s*\\(",
                    "captures": {
                        "1": {
                            "name": "entity.name.function.grynk"
                        }
                    }
                },
                {
                    "name": "entity.name.function.call.grynk",
                    "match": "\\b([a-zA-Z_]\\w*)\\s*\\("
                }
            ]
        },
        "builtins": {
            "patterns": [
                {
                    "name": "support.function.grynk",
                    "match": "\\b(say|ask)\\b"
                },
                {
                    "name": "support.class.gx.grynk",
                    "match": "\\bgx\\b"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.grynk",
                    "match": "(\\|>|\\*\\*|\\+=|-=|==|!=|<=|>=|<|>|=|\\+|-|\\*|/|%)"
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.float.grynk",
                    "match": "\\b\\d+\\.\\d+\\b"
                },
                {
                    "name": "constant.numeric.integer.grynk",
                    "match": "\\b\\d+\\b"
                }
            ]
        }
    },
    "scopeName": "source.grynk"
}