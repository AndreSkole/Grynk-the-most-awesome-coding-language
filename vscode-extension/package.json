{
  "name": "grynk-lang",
  "displayName": "Grynk Language Support",
  "description": "Language support and icon for the Grynk programming language",
  "version": "1.0.0",
  "publisher": "grynk",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages",
    "Themes"
  ],
  "contributes": {
    "languages": [
      {
        "id": "grynk",
        "aliases": [
          "Grynk",
          "grynk"
        ],
        "extensions": [
          ".grk"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./grynk-icon.png",
          "dark": "./grynk-icon.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "grynk",
        "scopeName": "source.grynk",
        "path": "./syntaxes/grynk.tmLanguage.json"
      }
    ],
    "iconThemes": [
      {
        "id": "grynk-icon-theme",
        "label": "Grynk Icon Theme",
        "path": "./grynk-icon-theme.json"
      }
    ]
  }
}